<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_ivory">

    <!-- Header Banner -->
    <View
        android:id="@+id/header_banner"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="@color/sage_green"
        android:layout_alignParentTop="true" />

    <!-- Container for Profile Picture to add simple shadow/border effect -->
    <RelativeLayout
        android:id="@+id/profile_container"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_below="@id/header_banner"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="-60dp"
        android:background="@color/white"
        android:elevation="8dp"
        android:padding="4dp">

        <TextView
            android:id="@+id/icon_profil"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/bg_ivory"
            android:gravity="center"
            android:text="🌸"
            android:textSize="60sp" />
    </RelativeLayout>

    <!-- Toko Info -->
    <TextView
        android:id="@+id/nama_toko"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/profile_container"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp"
        android:text="Akhyar Florist"
        android:textColor="@color/black"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/deskripsi_toko"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/nama_toko"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="4dp"
        android:text="Spesialis Rangkaian Bunga Segar &amp; Dekorasi Premium"
        android:textColor="@color/text_dark"
        android:textSize="14sp" />

    <!-- Stats Section -->
    <LinearLayout
        android:id="@+id/stats_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/deskripsi_toko"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:weightSum="3"
        android:paddingHorizontal="16dp">

        <!-- Rating -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⭐ 4.9"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/black" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1.2k Ulasan"
                android:textSize="12sp"
                android:textColor="@color/text_dark" />
        </LinearLayout>

        <!-- Lokasi -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Jaksel"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/black" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15 km"
                android:textSize="12sp"
                android:textColor="@color/text_dark" />
        </LinearLayout>

        <!-- Status -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🟢 Buka"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/sage_green" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="08:00 - 20:00"
                android:textSize="12sp"
                android:textColor="@color/text_dark" />
        </LinearLayout>

    </LinearLayout>

    <!-- Info Lanjut -->
    <TextView
        android:id="@+id/tentang_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/stats_layout"
        android:layout_marginLeft="24dp"
        android:layout_marginTop="32dp"
        android:text="Tentang Toko"
        android:textColor="@color/black"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tentang_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tentang_label"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="8dp"
        android:lineSpacingExtra="4dp"
        android:text="Akhyar Florist menyediakan bunga segar premium untuk berbagai acara Anda. Dari buket wisuda, pernikahan, hingga ucapan selamat, kami merangkai setiap tangkai dengan penuh cinta dan dedikasi. Pesan sekarang untuk pengiriman hari ini!"
        android:textColor="@color/text_dark"
        android:textSize="14sp" />

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_margin="24dp"
        android:orientation="horizontal"
        android:weightSum="2">

        <Button
            android:id="@+id/btn_chat"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1"
            android:layout_marginRight="8dp"
            android:backgroundTint="@color/white"
            android:text="💬 Chat"
            android:textColor="@color/sage_green"
            android:textStyle="bold"
            android:elevation="2dp" />

        <Button
            android:id="@+id/btn_pesan"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1"
            android:layout_marginLeft="8dp"
            android:backgroundTint="@color/sage_green"
            android:text="🛒 Pesan Sekarang"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:elevation="2dp" />
    </LinearLayout>

</RelativeLayout>